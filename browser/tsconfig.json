{
    "compilerOptions": {
        "strict": true,
        "module": "esnext",
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "moduleResolution": "bundler",
        "target": "esnext",
        "declaration": false,
        "noEmitOnError": true,
        "sourceMap": true,
        "jsx": "react-jsx",
        "rootDir": "..",
        "outDir": "./dist",
        "allowJs": true,
        "paths": {}
    },
        "include": [
            "./src/index.tsx",
            "./src/**/*",
            "../src/**/*"
        ],
    "exclude": [
        "node_modules"
    ]
}